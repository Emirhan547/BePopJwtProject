@using BePopJwt.WebUI.Dtos.AuthDtos
@model LoginDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="~/Bepop/assets/css/bootstrap.css" />
    <link rel="stylesheet" href="~/Bepop/assets/css/theme.css" />
</head>
<body class="layout-row bg-dark">
    <div class="container py-5 text-white" style="max-width:540px;">
        <h3>Sign In</h3>
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form asp-action="SignIn" method="post">
            <input asp-for="Request.Email" class="form-control mb-3" placeholder="Email" />
            <input asp-for="Request.Password" type="password" class="form-control mb-3" placeholder="Password" />
            <button class="btn btn-primary" type="submit">Giriş Yap</button>
            <a asp-action="SignUp" class="btn btn-link">Kayıt Ol</a>
        </form>
    </div></body>
</html>