@using BePopJwt.WebUI.Dtos.AuthDtos
@model RegisterDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Signup | Bepop</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- CSS -->
    <link rel="stylesheet" href="~/Bepop/libs/slick-carousel/slick/slick.css" />
    <link rel="stylesheet" href="~/Bepop/libs/slick-carousel/slick/slick-theme.css" />
    <link rel="stylesheet" href="~/Bepop/assets/css/bootstrap.css" />
    <link rel="stylesheet" href="~/Bepop/assets/css/theme.css" />
    <link rel="stylesheet" href="~/Bepop/assets/css/style.css" />
</head>

<body class="layout-row bg-dark">
    <div class="d-flex flex-column flex">
        <div class="row no-gutters h-100">

            <!-- LEFT -->
            <div class="col-md-6 bg-dark bg-img"
                 style="background-image:url('/images/SignUpImage.jpg')">

                <div class="p-4 p-md-5 d-flex flex-column h-100">
                    <h4 class="mb-3 text-white">Bepop</h4>
                    <div class="text-fade">Müzik Web Uygulaması</div>

                    <div class="flex"></div>

                    <div class="d-flex text-sm text-fade">
                        <a href="#" class="text-white">Hakkında</a>
                        <span class="flex"></span>
                        <a href="#" class="text-white mx-1">Şartlar</a>
                        <a href="#" class="text-white mx-1">Gizlilik</a>
                    </div>
                </div>
            </div>

            <!-- RIGHT -->
            <div class="col-md-6" id="content-body">
                <div class="p-4 p-md-5">

                    <h5>Bepop'a Hoş Geldin</h5>
                    <p>
                        <small class="text-muted">Hesabını oluştur</small>
                    </p>

                    <!-- ERROR -->
                    @if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage))
                    {
                        <div class="alert alert-danger">
                            @Model.ErrorMessage
                        </div>
                    }

                    <!-- FORM -->
                    <form asp-action="SignUp" method="post">

                        <div class="form-group">
                            <input asp-for="Request.UserName"
                                   class="form-control"
                                   placeholder="Username" />
                        </div>

                        <div class="form-group">
                            <input asp-for="Request.DisplayName"
                                   class="form-control"
                                   placeholder="Display Name" />
                        </div>

                        <div class="form-group">
                            <input asp-for="Request.Email"
                                   class="form-control"
                                   placeholder="Email" />
                        </div>

                        <div class="form-group">
                            <input asp-for="Request.Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="Password" />
                        </div>

                        <!-- PACKAGE -->
                        <div class="form-group">
                            <select asp-for="Request.PackageId" class="form-control">
                                @foreach (var package in Model.Packages.OrderBy(p => p.Level))
                                {
                                    <option value="@package.Id">
                                        @package.Name (Seviye @package.Level)
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mb-3 text-sm">
                            <span class="text-muted">
                                kullanım şartlarını
                            </span>
                            <a href="#">kabul etmiş olursun.</a>
                        </div>

                        <button type="submit" class="btn btn-primary mb-4">
                            Kayıt Ol
                        </button>

                        <div>
                            Zaten hesabın var mı?
                            <a asp-action="SignIn" class="text-primary _600">
                                Giriş Yap
                            </a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>

    <!-- JS -->
    <script src="~/Bepop/libs/jquery/dist/jquery.min.js"></script>
    <script src="~/Bepop/libs/popper.js/dist/umd/popper.min.js"></script>
    <script src="~/Bepop/libs/bootstrap/dist/js/bootstrap.min.js"></script>
    <script src="~/Bepop/libs/pjax/pjax.min.js"></script>
    <script src="~/Bepop/assets/js/ajax.js"></script>
    <script src="~/Bepop/assets/js/lazyload.config.js"></script>
    <script src="~/Bepop/assets/js/lazyload.js"></script>
    <script src="~/Bepop/assets/js/plugin.js"></script>
    <script src="~/Bepop/libs/scrollreveal/dist/scrollreveal.min.js"></script>
    <script src="~/Bepop/libs/slick-carousel/slick/slick.min.js"></script>
    <script src="~/Bepop/libs/feather-icons/dist/feather.min.js"></script>
    <script src="~/Bepop/assets/js/theme.js"></script>

</body>
</html>