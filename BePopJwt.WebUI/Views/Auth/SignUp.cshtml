@using BePopJwt.WebUI.Dtos.AuthDtos
@model RegisterDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="~/Bepop/assets/css/bootstrap.css" />
    <link rel="stylesheet" href="~/Bepop/assets/css/theme.css" />
</head>
<body class="layout-row bg-dark">
    <div class="container py-5 text-white" style="max-width:640px;">
        <h3>Sign Up</h3>
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form asp-action="SignUp" method="post">
            <input asp-for="Request.UserName" class="form-control mb-2" placeholder="Username" />
            <input asp-for="Request.DisplayName" class="form-control mb-2" placeholder="Display Name" />
            <input asp-for="Request.Email" class="form-control mb-2" placeholder="Email" />
            <input asp-for="Request.Password" type="password" class="form-control mb-2" placeholder="Password" />
            <select asp-for="Request.PackageId" class="form-control mb-3">
                @foreach (var package in Model.Packages.OrderBy(p => p.Level))
                {
                    <option value="@package.Id">@package.Name (Seviye @package.Level)</option>
                }
            </select>
            <button class="btn btn-primary" type="submit">Kayıt Ol</button>
            <a asp-action="SignIn" class="btn btn-link">Girişe Dön</a>
        </form>
    </div></body>
</html>