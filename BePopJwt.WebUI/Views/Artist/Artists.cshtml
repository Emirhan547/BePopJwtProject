@using BePopJwt.WebUI.Dtos.ArtistDtos
@model List<ArtistWithAlbumsDto>
@{
    ViewData["Title"] = "Artists";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}
<div id="main" class="layout-row flex">
    <div id="content" class="flex ">
        <div class="page-content page-container" id="page-content">
            <div class="padding sr">
                <div class="page-hero"><h1 class="display-4 text-white">Artists</h1><p class="text-muted">Backend artist + albums verilerinden dinamik liste.</p></div>
                <div class="row row-sm">
                    @foreach (var artist in Model)
                    {
                        <div class="col-12 col-md-6 col-lg-4 py-3">
                            <div class="list-item r box">
                                <div class="media"><a class="media-content" style="background-image:url(@(string.IsNullOrWhiteSpace(artist.ImageUrl) ? "/Bepop/assets/img/a1.jpg" : artist.ImageUrl))"></a></div>
                                <div class="list-content p-3">
                                    <div class="text-white h5">@artist.Name</div>
                                    <div class="text-muted text-sm mb-2">@artist.Bio</div>
                                    <div class="text-muted text-sm">Albüm (@artist.Albums.Count): @string.Join(", ", artist.Albums.Select(a => a.Name).Take(3))</div>
                                    <a href="@Url.Action("ArtistDetail", "Artist", new { id = artist.Id })" class="btn btn-sm btn-primary mt-3">Detayı Gör</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>