@using BePopJwt.WebUI.Dtos.SongDtos
@model List<SongWithAlbumDto>
@{
    ViewData["Title"] = "Charts";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}
<div id="main" class="layout-row flex">
    <div id="content" class="flex">
        <div class="page-content page-container p-5">
            <h2 class="text-white mb-4">Top Charts</h2>
            <table class="table table-dark table-striped">
                <thead><tr><th>#</th><th>Şarkı</th><th>Albüm</th><th>Seviye</th></tr></thead>
                <tbody>
                    @for (var i = 0; i < Model.Count; i++)
                    {
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@Model[i].Name</td>
                            <td>@(Model[i].Album?.Name ?? "-")</td>
                            <td>@Model[i].Level</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>    </div>
    </div>