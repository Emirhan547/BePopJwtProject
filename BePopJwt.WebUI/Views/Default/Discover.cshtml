@using BePopJwt.WebUI.Dtos.HomeDtos
@model DiscoverViewModel
@{
    ViewData["Title"] = "Discover";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}
<div id="main" class="layout-row flex">
    <div id="content" class="flex ">
        <div>
            <div class="page-content page-container" id="page-content">
                <div class="padding sr">
                    <div class="page-hero">
                        <div class="media bg-media"><div class="media-content" style="background-image:url(/Bepop/assets/img/b9.jpg)"></div></div>
                        <div class="pos-rlt">
                            <h2 class="display-3 font-weight-bold text-white">Discover</h2>
                            <p class="text-muted col-md-8 px-0">Paket seviyene göre erişebileceğin şarkılar ve kişisel öneriler.</p>
                            @if (Model.Session.IsAuthenticated)
                            {
                                <span class="badge badge-pill badge-primary">Paketin: @Model.Session.PackageName (@Model.Session.PackageLevel)</span>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="alert alert-warning mt-3">@Model.ErrorMessage</div>
                    }

                    <h5 class="mt-5 text-highlight">Önerilen Şarkılar</h5>
                    <form method="get" class="row mb-3">
                        <div class="col-md-4">
                            <label class="text-muted">Ruh halin</label>
                            <select name="mood" class="form-control" onchange="this.form.submit()">
                                <option value="mutlu" selected="@(Model.SelectedMood == "mutlu")">Mutlu</option>
                                <option value="enerjik" selected="@(Model.SelectedMood == "enerjik")">Enerjik</option>
                                <option value="sakin" selected="@(Model.SelectedMood == "sakin")">Sakin</option>
                                <option value="hüzünlü" selected="@(Model.SelectedMood == "hüzünlü")">Hüzünlü</option>
                                <option value="odak" selected="@(Model.SelectedMood == "odak")">Odak</option>
                            </select>
                        </div>
                    </form>
                    <div class="row row-sm" id="recommendation-grid">
                        @foreach (var song in Model.RecommendedSongs)
                        {
                            <div class="col-6 col-md-4 col-lg-3 py-2 recommendation-card">
                                <div class="list-item r box">
                                    <div class="media"><a data-song-id="@song.Id" href="@Url.Action("SongDetail", "Default", new { id = song.Id, autoPlay = true })" class="media-content js-song-link" style="background-image:url(@(string.IsNullOrWhiteSpace(song.CoverUrl) ? "/Bepop/assets/img/b2.jpg" : song.CoverUrl)"></a></div>
                                    <div class="list-content p-2">
                                        <div class="list-body"><span class="list-title text-white">@song.Name</span><div class="text-muted text-sm">@(song.Album?.Name ?? "-")</div></div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="row mt-4">
                        <div class="col-md-4">
                            <input id="song-search" class="form-control" placeholder="Şarkı veya albüm ara" />
                        </div>
                        <div class="col-md-4 mt-2 mt-md-0">
                            <select id="song-filter" class="form-control">
                                <option value="all">Tüm şarkılar</option>
                                <option value="favorites">Sadece favoriler</option>
                                <option value="unplayed">Henüz dinlemediklerim</option>
                            </select>
                        </div>
                        <div class="col-md-4 mt-2 mt-md-0 text-md-right">
                            <small class="text-muted">Toplam: <span id="visible-count">0</span> şarkı</small>
                        </div>
                    </div>
                    <h5 class="mt-4 text-highlight">Sana Açık Şarkılar</h5>
                    <div class="row row-sm" id="discover-song-grid">
                        @foreach (var song in Model.AccessibleSongs)
                        {
                            <div class="col-12 col-md-6 py-2 song-card" data-song-id="@song.Id" data-song-name="@song.Name.ToLowerInvariant()" data-album-name="@(song.Album?.Name?.ToLowerInvariant() ?? "")">
                                <div class="d-flex b-a rounded p-2 align-items-center">
                                    <img src="@(string.IsNullOrWhiteSpace(song.CoverUrl) ? "/Bepop/assets/img/b1.jpg" : song.CoverUrl)" width="56" height="56" class="rounded" />
                                    <div class="px-3 flex">
                                        <div class="text-white"><a class="text-white js-song-link" data-song-id="@song.Id" href="@Url.Action("SongDetail", "Default", new { id = song.Id, autoPlay = true })">@song.Name</a></div>
                                        <small class="text-muted">@(song.Album?.Name ?? "-")</small>
                                        <div><span class="badge badge-secondary">Şarkı @song.Level</span></div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-warning favorite-btn mr-2" data-song-id="@song.Id">☆</button>
                                    <button class="btn btn-sm btn-primary play-btn" data-song-id="@song.Id">Play</button>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-4 p-3 b-a rounded">
                        <h6 class="text-highlight">Web Player</h6>
                        <audio id="web-player" controls class="w-100"></audio>
                        <small class="text-muted" id="player-status">Şarkı seç ve oynat.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const player = document.getElementById('web-player');
        const status = document.getElementById('player-status');
        const searchInput = document.getElementById('song-search');
        const filterSelect = document.getElementById('song-filter');
        const visibleCount = document.getElementById('visible-count');
        const cards = Array.from(document.querySelectorAll('.song-card'));
        const historySongIds = new Set(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.History.Select(x => x.SongId).Distinct().ToList())));
        const recommendationGrid = document.getElementById('recommendation-grid');

        function renderRecommendations(songs) {
            if (!recommendationGrid) return;
            recommendationGrid.innerHTML = (songs || []).map(song => {
                const cover = song.coverUrl || '/Bepop/assets/img/b2.jpg';
                const albumName = (song.album && song.album.name) ? song.album.name : '-';
                return `<div class="col-6 col-md-4 col-lg-3 py-2 recommendation-card">
                    <div class="list-item r box">
                        <div class="media"><a class="media-content" style="background-image:url(${cover})"></a></div>
                        <div class="list-content p-2">
                            <div class="list-body"><span class="list-title text-white">${song.name}</span><div class="text-muted text-sm">${albumName}</div></div>
                        </div>
                    </div>
                </div>`;
            }).join('');
        }

        async function refreshRecommendations() {
            const response = await fetch(`@Url.Action("Recommendations", "Default")?take=8`);
            if (!response.ok) return;
            const data = await response.json();
            if (data.ok && Array.isArray(data.songs)) {
                renderRecommendations(data.songs);
            }
        }
        let favorites = new Set(JSON.parse(localStorage.getItem('bePopFavorites') || '[]'));
        let currentSongId = 0;
        let startedAt = null;
        function syncFavoriteButtons() {
            document.querySelectorAll('.favorite-btn').forEach(btn => {
                const songId = Number(btn.dataset.songId || 0);
                const isFav = favorites.has(songId);
                btn.textContent = isFav ? '★' : '☆';
                btn.classList.toggle('btn-warning', isFav);
                btn.classList.toggle('btn-outline-warning', !isFav);
            });
        }

        function applyFilters() {
            const query = (searchInput.value || '').trim().toLowerCase();
            const mode = filterSelect.value;
            let count = 0;

            cards.forEach(card => {
                const songId = Number(card.dataset.songId || 0);
                const name = card.dataset.songName || '';
                const album = card.dataset.albumName || '';

                const matchQuery = !query || name.includes(query) || album.includes(query);
                const matchMode = mode === 'all'
                    || (mode === 'favorites' && favorites.has(songId))
                    || (mode === 'unplayed' && !historySongIds.has(songId));

                const visible = matchQuery && matchMode;
                card.style.display = visible ? '' : 'none';
                if (visible) count++;
            });

            visibleCount.textContent = count;
        }

        document.querySelectorAll('.favorite-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const songId = Number(btn.dataset.songId || 0);
                if (!songId) return;

                if (favorites.has(songId)) favorites.delete(songId);
                else favorites.add(songId);

                localStorage.setItem('bePopFavorites', JSON.stringify(Array.from(favorites)));
                syncFavoriteButtons();
                applyFilters();
            });
        });
        document.querySelectorAll('.play-btn').forEach(btn => {
           btn.addEventListener('click', async () => {
                currentSongId = Number(btn.dataset.songId || 0);
                const sourceResponse = await fetch(`@Url.Action("SongSource", "Default")?songId=${currentSongId}`);
                const sourceData = await sourceResponse.json();
                if (!sourceResponse.ok || !sourceData.ok || !sourceData.source) {
                    status.textContent = sourceData.message || 'Şarkı kaynağına erişilemedi.';
                    return;
                }
                player.src = sourceData.source;
                player.play();
                startedAt = Date.now();
                status.textContent = 'Çalıyor...';
            });
        });
        searchInput.addEventListener('input', applyFilters);
        filterSelect.addEventListener('change', applyFilters);
        player.addEventListener('ended', sendPlayHistory);

        async function sendPlayHistory() {
            if (!currentSongId || !startedAt) return;
            const duration = Math.max(1, Math.floor((Date.now() - startedAt) / 1000));

            const response = await fetch('@Url.Action("Play", "Default")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ songId: currentSongId, playDuration: duration })
            });

            if (response.ok) {
                historySongIds.add(currentSongId);
                status.textContent = 'Dinleme kaydı alındı.';
                applyFilters();
                await refreshRecommendations();
            } else {
                status.textContent = 'Dinleme kaydı alınamadı.';
            }
        }
        syncFavoriteButtons();
        applyFilters();
        refreshRecommendations();
    })();
</script>