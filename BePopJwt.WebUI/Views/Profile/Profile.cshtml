@model BePopJwt.WebUI.Dtos.UserDtos.UserProfileDto
@{
    ViewData["Title"] = "Profil";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}
<div id="main" class="layout-row flex">
    <div id="content" class="flex ">
        <div class="page-content page-container" id="page-content">
            <div class="padding sr">
                <div class="page-hero">
                    <h2 class="display-4 text-white">Profil Ayarları</h2>
                    <p class="text-muted">Hesap bilgilerini güncelle, görselini değiştir ve profilini kişiselleştir.</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger mt-3">@ViewBag.Error</div>
                }
                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-success mt-3">@ViewBag.Success</div>
                }

                <div class="row mt-3">
                    <div class="col-12 col-lg-4 mb-3">
                        <div class="b-a rounded p-3 h-100">
                            <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "/images/Emirhan.jpeg" : Model.ImageUrl)" width="120" height="120" class="rounded-circle d-block mx-auto" />
                            <div class="text-center mt-3">
                                <h4 class="text-white mb-1">@Model.DisplayName</h4>
                                <div class="text-muted">@Model.UserName</div>
                                <div class="text-muted">@Model.Email</div>
                                <span class="badge badge-pill badge-primary mt-2">@Model.PackageName </span>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-8">
                        <form method="post" class="b-a rounded p-3">
                            @Html.AntiForgeryToken()
                            <div class="form-group">
                                <label class="text-muted">Görünen Ad</label>
                                <input name="DisplayName" value="@Model.DisplayName" class="form-control" required />
                            </div>
                            <div class="form-group">
                                <label class="text-muted">Kullanıcı Adı</label>
                                <input name="UserName" value="@Model.UserName" class="form-control" required />
                            </div>
                            <div class="form-group">
                                <label class="text-muted">Email</label>
                                <input name="Email" type="email" value="@Model.Email" class="form-control" required />
                            </div>
                            <div class="form-group">
                                <label class="text-muted">Profil Görsel URL</label>
                                <input name="ImageUrl" value="@Model.ImageUrl" class="form-control" placeholder="https://..." />
                            </div>
                            <button type="submit" class="btn btn-primary">Profili Güncelle</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>